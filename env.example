# Project Environment Configuration
# Copy this file to .env in your project root and configure the values.
#
# IMPORTANT: Never commit .env files with real values to version control.
# Add .env to your .gitignore file.

# =============================================================================
# PROMPT LIBRARY CONFIGURATION (Required)
# =============================================================================

# Path to the LLM Pre-prompts repository on your local machine.
# Agents use this to compute prompt file hashes and track provenance.
#
# Example: /home/user/Development/LLM_Pre-prompts
PROMPT_LIBRARY_PATH=/path/to/LLM_Pre-prompts

# =============================================================================
# GPG SIGNING CONFIGURATION (Required)
# =============================================================================

# Your GPG key ID for signing build attestations.
# Builds will fail without a valid signing key.
#
# To find your key ID:
#   gpg --list-secret-keys --keyid-format LONG
#
# To generate a new key:
#   gpg --full-generate-key
#
# Example: ABCD1234EFGH5678
GPG_SIGNING_KEY_ID=YOUR_GPG_KEY_ID_HERE

# =============================================================================
# GITHUB CONFIGURATION (Optional - for issue automation)
# =============================================================================

# GitHub Personal Access Token for API access.
# Required only if issue_automation.enabled is true in project.manifest.yaml.
#
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos)
#
# Example: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_TOKEN=

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Override the default GPG home directory (rarely needed)
# GNUPGHOME=~/.gnupg

# Enable verbose logging for debugging
# DEBUG=true
